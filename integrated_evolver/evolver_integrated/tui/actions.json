{
  "version": 1,
  "panels": {
    "live": {
      "tabs": {
        "experiments": {
          "textual_actions": [
            "fuzzy_search",
            "open_item",
            "new_exp",
            "edit_item",
            "delete_item",
            "pause_or_resume",
            "cancel_exp",
            "run_or_restart"
          ]
        },
        "evolvers": {
          "textual_actions": [
            "fuzzy_search",
            "open_item",
            "config_item",
            "edit_item",
            "delete_item"
          ]
        },
        "services": {
          "textual_actions": [
            "fuzzy_search",
            "open_item",
            "config_item",
            "pause_or_resume",
            "run_or_restart",
            "start_service",
            "stop_service"
          ]
        }
      }
    }
  },
  "service_lifecycle": {
    "managed_only_textual_actions": [
      "pause_or_resume",
      "run_or_restart"
    ],
    "commands": {
      "start": "start",
      "stop": "stop",
      "pause": "pause",
      "resume": "resume",
      "restart": "restart"
    }
  },
  "key_help": [
    {"key": "0", "description": "focus context/details pane"},
    {"key": "1-5", "description": "focus numbered windows"},
    {"key": "[ / ] or left/right", "description": "switch tabs inside focused window"},
    {"key": "?", "description": "search available keybindings"},
    {"key": "/", "description": "fuzzy search current list"},
    {"key": "a", "description": "add entry in editable list scopes"},
    {"key": "e", "description": "edit focused entry in editable list scopes"},
    {"key": "delete", "description": "delete focused entry in editable list scopes"},
    {"key": "enter", "description": "opens focused row; starts inactive services"},
    {"key": "space", "description": "runs the current scope option when enabled"},
    {"key": "r", "description": "restart focused service or run selected experiment"},
    {"key": "p", "description": "pause/resume supported live entries"},
    {"key": "x", "description": "stop/delete supported focused entries"},
    {"key": "d", "description": "load demo data"},
    {"key": "q or ctrl+c", "description": "exit TUI"},
    {"key": "escape", "description": "clears transient focus"}
  ]
}
