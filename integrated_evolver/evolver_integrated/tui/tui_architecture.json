{
  "version": 2,
  "inheritance": {
    "context": {
      "default": false,
      "merge": "nearest scope wins; object values merge downward"
    },
    "options": {
      "default": false,
      "merge": "nearest scope wins; object values merge downward"
    },
    "keybinds": {
      "merge": "inherited groups first, then scope-specific modifications and additions"
    }
  },
  "pages": [
    {
      "id": "operational",
      "number": 0,
      "name": "Operational Console",
      "title": "eVOLVER Control",
      "context": {
        "scope": "page.operational",
        "summary": "default always-visible runtime console"
      },
      "options": {
        "can_toggle_option": false,
        "opens_form": false
      },
      "windows": [
        {
          "id": "context",
          "number": 0,
          "name": "Context",
          "title": "Context",
          "role": "scrollable detail pane",
          "global_key": "0",
          "context": {
            "scope": "context",
            "shows": [
              "focused scope overview",
              "focused item details",
              "nested parent context for protocol -> step -> component"
            ]
          },
          "keybinds": {
            "inherits": ["global_keybindings"]
          }
        },
        {
          "id": "status",
          "number": 1,
          "name": "Status",
          "title": "Status",
          "global_key": "1",
          "context": {
            "scope": "status",
            "shows": ["runtime health", "highest-priority system condition"]
          },
          "options": {
            "jumps_to_recovery_context": true
          },
          "keybinds": {
            "inherits": ["global_keybindings"],
            "available": [
              {
                "key": "enter",
                "action": "status.open_recovery_context",
                "label": "Open relevant recovery context",
                "enabled_when": "status.options.jumps_to_recovery_context"
              },
              {
                "key": "space",
                "action": "status.open_recovery_context",
                "label": "Open relevant recovery context",
                "enabled_when": "status.options.jumps_to_recovery_context"
              }
            ]
          }
        },
        {
          "id": "live",
          "number": 2,
          "name": "Live",
          "title": "Live",
          "global_key": "2",
          "context": {
            "scope": "live",
            "shows": ["runtime objects"]
          },
          "keybinds": {
            "inherits": ["global_keybindings", "tab_keybindings"]
          },
          "tabs": [
            {
              "id": "experiments",
              "name": "Experiments",
              "context": {
                "scope": "live.experiments",
                "item_context": "experiment.focused"
              },
              "data": {
                "source": "json_store.experiments",
                "empty_state": "No experiments",
                "rows": [
                  {"field": "state", "display": "state icon", "fallback": "?"},
                  {"field": "request.name", "display": "experiment name", "fallback": "id"},
                  {"field": "state", "display": "state label", "fallback": "?"},
                  {"field": "request.metadata.protocol", "display": "protocol name", "fallback": "default", "detail_only": true},
                  {"field": "created_at", "display": "created time", "fallback": "?", "detail_only": true},
                  {"field": "runner.state", "display": "runner state", "fallback": "-", "detail_only": true}
                ]
              },
              "options": {
                "opens_form": true
              },
              "keybinds": {
                "inherits": ["list_keybindings"],
                "available": [
                  {"key": "a", "action": "experiment.create", "label": "Add experiment", "enabled_when": "options.opens_form"},
                  {"key": "enter", "action": "experiment.open", "label": "Open experiment details"},
                  {"key": "r", "action": "experiment.run", "label": "Run focused experiment"},
                  {"key": "p", "action": "experiment.pause_or_resume", "label": "Pause/resume focused experiment"},
                  {"key": "c", "action": "experiment.cancel", "label": "Cancel focused experiment"},
                  {"key": "e", "action": "experiment.edit", "label": "Edit focused experiment"},
                  {"key": "delete", "action": "experiment.delete", "label": "Delete focused experiment"}
                ]
              }
            },
            {
              "id": "evolver_units",
              "name": "Evolver Units",
              "context": {
                "scope": "live.evolver_units",
                "item_context": "evolver.focused"
              },
              "data": {
                "source": "json_store.evolver_units",
                "empty_state": "No eVOLVER units connected",
                "rows": [
                  {"field": "state", "display": "state icon", "fallback": "unknown"},
                  {"field": "name", "display": "unit name", "fallback": "id"},
                  {"field": "state", "display": "unit state label", "fallback": "unknown"},
                  {"field": "role", "display": "unit role", "fallback": "-", "detail_only": true},
                  {"field": "devices", "display": "attached device count and names", "fallback": [], "detail_only": true}
                ]
              },
              "keybinds": {
                "inherits": ["list_keybindings"],
                "available": [
                  {"key": "a", "action": "evolver.import_or_configure", "label": "Add/import evolver unit"},
                  {"key": "enter", "action": "evolver.open", "label": "Open unit details"},
                  {"key": "space", "action": "evolver.configure", "label": "Open unit config", "enabled_when": "focused_item.options.opens_form"},
                  {"key": "e", "action": "evolver.edit", "label": "Edit unit"},
                  {"key": "delete", "action": "evolver.delete", "label": "Delete unit"}
                ]
              }
            },
            {
              "id": "services",
              "name": "Services",
              "context": {
                "scope": "live.services",
                "item_context": "service.focused"
              },
              "data": {
                "source": "control_api.list_services",
                "empty_state": "No configured services",
                "rows": [
                  {"field": "state", "display": "service state icon", "fallback": "unknown"},
                  {"field": "name", "display": "service name", "fallback": "id"},
                  {"field": "category", "display": "service category", "fallback": "?"},
                  {"field": "state", "display": "service state label", "fallback": "unknown"},
                  {"field": "restart_count", "display": "restart count", "fallback": 0, "detail_only": true},
                  {"field": "last_action", "display": "last lifecycle action", "fallback": "-", "detail_only": true},
                  {"field": "description", "display": "description", "fallback": "", "detail_only": true}
                ]
              },
              "options": {
                "opens_form": true
              },
              "keybinds": {
                "inherits": ["list_keybindings"],
                "modifies": [
                  {"key": "enter", "action": "service.start_if_inactive", "label": "Start inactive service", "enabled_when": "focused_item.state != 'running'"},
                  {"key": "space", "action": "service.config", "label": "Open service config popup", "enabled_when": "options.opens_form"}
                ],
                "available": [
                  {"key": "r", "action": "service.restart", "label": "Restart focused service"},
                  {"key": "p", "action": "service.pause_or_resume", "label": "Pause/resume focused service"},
                  {"key": "s", "action": "service.start", "label": "Start focused service"},
                  {"key": "x", "action": "service.stop", "label": "Stop focused service"},
                  {"key": "/", "action": "service.search", "label": "Search services"}
                ]
              }
            }
          ]
        },
        {
          "id": "inventory",
          "number": 3,
          "name": "Inventory",
          "title": "Inventory",
          "global_key": "3",
          "context": {
            "scope": "inventory",
            "shows": ["reusable definitions and configured resources"]
          },
          "keybinds": {
            "inherits": ["global_keybindings", "tab_keybindings"]
          },
          "tabs": [
            {
              "id": "protocols",
              "name": "Protocols",
              "context": {
                "scope": "inventory.protocols",
                "item_context": "inventory.protocols.focused",
                "focused_context": "inventory.protocols.focused"
              },
              "data": {
                "source": "json_store.protocols",
                "empty_state": "No protocols - create one first",
                "rows": [
                  {"field": "name", "display": "protocol name", "fallback": "?"},
                  {"field": "steps", "display": "step count", "fallback": []},
                  {"field": "id", "display": "protocol id", "fallback": "-", "detail_only": true},
                  {"field": "description", "display": "description", "fallback": "", "detail_only": true}
                ]
              },
              "options": {
                "opens_form": true
              },
              "keybinds": {
                "inherits": ["list_keybindings"],
                "available": [
                  {"key": "a", "action": "protocol.create", "label": "Add protocol", "enabled_when": "options.opens_form"},
                  {"key": "enter", "action": "protocol.open", "label": "Open protocol"},
                  {"key": "e", "action": "protocol.edit", "label": "Edit protocol"},
                  {"key": "delete", "action": "protocol.delete", "label": "Delete protocol"}
                ]
              }
            },
            {
              "id": "materials",
              "name": "Materials",
              "context": {
                "scope": "inventory.materials",
                "item_context": "inventory.materials.focused"
              },
              "data": {
                "source": "json_store.materials",
                "empty_state": "No materials registered",
                "rows": [
                  {"field": "name", "display": "material name", "fallback": "?"},
                  {"field": "type", "display": "material type", "fallback": "?"},
                  {"field": "id", "display": "material id", "fallback": ""},
                  {"field": "lot", "display": "lot", "fallback": "-", "detail_only": true},
                  {"field": "description", "display": "description", "fallback": "No description.", "detail_only": true}
                ]
              },
              "options": {
                "opens_form": true
              },
              "keybinds": {
                "inherits": ["list_keybindings"],
                "available": [
                  {"key": "a", "action": "material.create", "label": "Add material", "enabled_when": "options.opens_form"},
                  {"key": "enter", "action": "material.open", "label": "Open material"},
                  {"key": "e", "action": "material.edit", "label": "Edit material"},
                  {"key": "delete", "action": "material.delete", "label": "Delete material"}
                ]
              }
            },
            {
              "id": "devices",
              "name": "Devices",
              "context": {
                "scope": "inventory.devices",
                "item_context": "inventory.devices.focused"
              },
              "data": {
                "source": "json_store.devices",
                "empty_state": "No devices configured",
                "rows": [
                  {"field": "name", "display": "device name", "fallback": "?"},
                  {"field": "type", "display": "device type", "fallback": "?"},
                  {"field": "io_role", "display": "I/O role", "fallback": "", "optional": true},
                  {"field": "id", "display": "device id", "fallback": "-", "detail_only": true},
                  {"field": "evolver_id", "display": "owning evolver unit", "fallback": "-", "detail_only": true}
                ]
              },
              "options": {
                "opens_form": true
              },
              "keybinds": {
                "inherits": ["list_keybindings"],
                "available": [
                  {"key": "a", "action": "device.create", "label": "Add device", "enabled_when": "options.opens_form"},
                  {"key": "u", "action": "device.auto_discover", "label": "Auto discover devices"},
                  {"key": "enter", "action": "device.open", "label": "Open device"},
                  {"key": "e", "action": "device.edit", "label": "Edit device"},
                  {"key": "delete", "action": "device.delete", "label": "Delete device"}
                ]
              }
            }
          ]
        },
        {
          "id": "steps",
          "number": 4,
          "name": "Steps",
          "title": "Steps",
          "global_key": "4",
          "context": {
            "scope": "steps",
            "inherits_focus_from": "inventory.protocols.focused",
            "item_context": "steps.focused",
            "focused_context": "steps.focused"
          },
          "keybinds": {
            "inherits": ["global_keybindings", "list_keybindings"],
            "available": [
              {"key": "enter", "action": "step.open", "label": "Open step context"},
              {"key": "a", "action": "step.create", "label": "Add step"},
              {"key": "e", "action": "step.edit", "label": "Edit step"},
              {"key": "delete", "action": "step.delete", "label": "Delete step"}
            ]
          },
          "tabs": [
            {
              "id": "default",
              "name": "Steps",
              "data": {
                "source": "json_store.protocols.focused.steps",
                "empty_state": "No steps defined",
                "rows": [
                  {"field": "index", "display": "1-based step order", "fallback": "row index"},
                  {"field": "progress", "display": "completion/current/future icon", "fallback": "future"},
                  {"field": "name", "display": "step name", "fallback": "stringified step"},
                  {"field": "description", "display": "description", "fallback": "No step description.", "detail_only": true},
                  {"field": "components", "display": "component count", "fallback": [], "detail_only": true}
                ]
              }
            }
          ]
        },
        {
          "id": "components",
          "number": 5,
          "name": "Components",
          "title": "Components",
          "global_key": "5",
          "context": {
            "scope": "components",
            "inherits_focus_from": "steps.focused",
            "item_context": "components.focused"
          },
          "options": {
            "can_toggle_option": true
          },
          "keybinds": {
            "inherits": ["global_keybindings", "list_keybindings"],
            "available": [
              {"key": "space", "action": "component.toggle_enabled", "label": "Toggle component enabled", "enabled_when": "options.can_toggle_option"},
              {"key": "enter", "action": "component.open", "label": "Open component context"},
              {"key": "a", "action": "component.create", "label": "Add component"},
              {"key": "e", "action": "component.edit", "label": "Edit component"},
              {"key": "delete", "action": "component.delete", "label": "Delete component"}
            ]
          },
          "tabs": [
            {
              "id": "default",
              "name": "Components",
              "data": {
                "source": "json_store.protocols.focused.steps.focused.components",
                "references": [
                  "json_store.materials",
                  "json_store.devices"
                ],
                "empty_state": "No components defined for this step",
                "rows": [
                  {"field": "enabled", "display": "enabled underline state", "fallback": true},
                  {"field": "name", "display": "component name", "fallback": "?"},
                  {"field": "type", "display": "component type", "fallback": ""},
                  {"field": "io_role", "display": "I/O role", "fallback": "", "optional": true}
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "global_keybindings": [
    {"key": "0", "action": "focus_context", "description": "Focus context pane for scrolling"},
    {"key": "1-5", "action": "focus_window", "description": "Focus numbered windows"},
    {"key": "?", "action": "key_help", "description": "Fuzzy search available keybindings"},
    {"key": "q", "action": "quit", "description": "Exit TUI"},
    {"key": "ctrl+c", "action": "dismiss_or_quit", "description": "Dismiss popup first, otherwise exit TUI"},
    {"key": "esc", "action": "clear_focus", "description": "Clear transient focus where supported"}
  ],
  "tab_keybindings": [
    {"key": "left/[", "action": "previous_tab", "description": "Switch to previous tab in the focused window"},
    {"key": "right/]", "action": "next_tab", "description": "Switch to next tab in the focused window"}
  ],
  "list_keybindings": [
    {"key": "up/down", "action": "move_focus", "description": "Move transient focus within current list"},
    {"key": "space", "action": "option_action", "description": "Run the focused scope option, such as config or toggle, only where that option is enabled"},
    {"key": "enter", "action": "open", "description": "Open detail popup or form where supported"},
    {"key": "a", "action": "add", "description": "Add entry for the current tab when form options are enabled"},
    {"key": "e", "action": "edit", "description": "Edit focused entry"},
    {"key": "delete", "action": "delete", "description": "Delete focused entry"},
    {"key": "/", "action": "search", "description": "Fuzzy search current list"}
  ],
  "focus_model": {
    "ui_only": true,
    "description": "Highlighted rows are durable focused context. A dependent window reads the focused row from its parent window until that parent window highlights a different row or switches tabs.",
    "selection_states": [
      "none",
      "focused",
      "focused_in_inactive_window"
    ],
    "option_actions": [
      {
        "type": "toggle",
        "description": "Toggles an enabled/value flag, such as component enabled."
      },
      {
        "type": "form",
        "description": "Opens a popup form and does not retain persistent focus after the form closes."
      }
    ]
  },
  "forms": {
    "constraints": [
      "only one popup at a time",
      "tab/shift+tab moves between fields",
      "progress is retained while moving between fields",
      "supports text entry, checkbox, and multi-select fields",
      "field options may depend on focused UI context"
    ],
    "planned_forms": [
      "experiment.create",
      "evolver.import_or_configure",
      "inventory.protocol.create",
      "inventory.material.create",
      "inventory.device.create"
    ]
  },
  "demo_mode": {
    "startup_flag": "--demo",
    "runtime_key": "d",
    "data_file": "demo_data.json"
  }
}
