          "description": "Dilute culture when OD exceeds threshold.",
          "components": [
            {"name": "media pump", "type": "pump", "io_role": "media_in", "enabled": true},
            {"name": "waste pump", "type": "pump", "io_role": "waste_out", "enabled": true}
          ]
        }
      ]
    },
    {
      "id": "calibration-demo",
