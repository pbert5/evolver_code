  "protocols": [
    {
      "id": "growth-curve-standard",
      "name": "Growth curve",
      "description": "Monitor culture growth with temperature and stirring setpoints. Pump feedback is intentionally disabled.",
      "protocol_type": "growth_curve",
      "version": "demo-2026.07",
      "algorithm_id": "alg-growth-curve-monitor",
      "required_device_types": ["smart_sleeve"],
      "required_component_types": ["vial", "od_sensor", "temperature_sensor", "stirbar"],
      "required_materials": [
        {"material_id": "mat-placeholder-growth-media", "material_type": "growth_medium", "role": "media_input", "placeholder_allowed": true, "user_fill_required": true, "run_blocking_if_unresolved": true},
        {"material_id": "mat-placeholder-starting-culture", "material_type": "starting_inoculum", "role": "inoculum", "placeholder_allowed": true, "user_fill_required": true, "run_blocking_if_unresolved": true}
      ],
      "initial_conditions": [
        {"parameter": "temperature", "value": {"value": 30, "unit": "degree_C"}},
        {"parameter": "stir_rate", "value": {"value": 8, "unit": "setting"}},
        {"parameter": "culture_volume", "value": {"value": 30, "unit": "mL"}}
      ],
      "steps": [
        {
          "id": "growth-load-media",
          "name": "load sterile media",
          "description": "Fill autoclaved vials with sterile media and place them in Smart Sleeves.",
          "step_type": "load_vials",
          "execution_mode": "manual",
          "order_index": 1,
          "component_configurations": [
            {"component_id": "mini-vial-0", "role": "culture_vessel"},
            {"component_id": "mini-vial-1", "role": "culture_vessel"}
          ],
          "material_inputs": [
            {"input_type": "initial_fill", "controlled_by_evolver": false, "material_id": "mat-placeholder-growth-media", "amount": {"value": 30, "unit": "mL"}}
          ]
        },
        {
          "id": "growth-preheat-stir",
          "name": "preheat and stir",
          "description": "Set temperature and stir for equilibration before inoculation.",
          "step_type": "set_initial_conditions",
          "execution_mode": "automatic",
          "order_index": 2,
          "fixed_parameters": [
            {"parameter": "temperature", "value": {"value": 30, "unit": "degree_C"}},
            {"parameter": "stir_rate", "value": {"value": 8, "unit": "setting"}}
          ],
          "action_ids": ["action-set-stir-rate"]
        },
        {
          "id": "growth-monitor",
          "name": "spike cells and monitor",
          "description": "Add saturated culture, then record OD and temperature until saturation.",
          "step_type": "monitor_growth",
          "execution_mode": "background_control_loop",
          "order_index": 3,
          "component_configurations": [
            {"component_id": "mini-od-0", "role": "optical_density"},
            {"component_id": "mini-temp-0", "role": "temperature"}
          ],
          "material_inputs": [
            {"input_type": "sample_spike", "controlled_by_evolver": false, "material_id": "mat-placeholder-starting-culture", "amount": {"value": 1, "unit": "mL"}}
          ],
          "objectives": [
            {"objective_type": "collect_data", "parameter": "optical_density", "modification_strategy": {"strategy_type": "no_feedback"}}
          ],
          "action_ids": ["action-read-od", "action-read-temperature"]
        }
      ],
      "documentation_ids": ["doc-growth-curve"]
    },
    {
      "id": "chemostat-standard",
      "name": "Chemostat",
      "description": "Maintain a fixed dilution rate with small pump boluses after OD and time gates are satisfied.",
      "protocol_type": "chemostat",
      "version": "demo-2026.07",
      "algorithm_id": "alg-chemostat-bolus-scheduler",
      "required_device_types": ["smart_sleeve", "pump_rack"],
      "required_component_types": ["vial", "od_sensor", "temperature_sensor", "stirbar", "pump_influx", "pump_efflux"],
      "required_materials": [
        {"material_id": "mat-placeholder-limiting-media", "material_type": "growth_medium", "role": "media_input", "placeholder_allowed": true, "user_fill_required": true, "run_blocking_if_unresolved": true},
        {"material_id": "mat-placeholder-starting-culture", "material_type": "starting_inoculum", "role": "inoculum", "placeholder_allowed": true, "user_fill_required": true, "run_blocking_if_unresolved": true},
        {"material_id": "mat-waste-output", "material_type": "waste", "role": "waste_output", "placeholder_allowed": false, "user_fill_required": false, "run_blocking_if_unresolved": false}
      ],
      "initial_conditions": [
        {"parameter": "temperature", "value": {"value": 30, "unit": "degree_C"}},
        {"parameter": "stir_rate", "value": {"value": 8, "unit": "setting"}},
        {"parameter": "culture_volume", "value": {"value": 30, "unit": "mL"}},
        {"parameter": "dilution_rate", "value": {"value": 0.231, "unit": "1/hr"}}
      ],
      "steps": [
        {
          "id": "chemostat-load",
          "name": "load culture and limiting media",
          "description": "Connect media and waste lines and load starting culture.",
          "step_type": "setup_connections",
          "execution_mode": "manual",
          "order_index": 1,
          "material_inputs": [
            {"input_type": "initial_fill", "controlled_by_evolver": false, "material_id": "mat-placeholder-limiting-media", "amount": {"value": 30, "unit": "mL"}},
            {"input_type": "sample_spike", "controlled_by_evolver": false, "material_id": "mat-placeholder-starting-culture", "amount": {"value": 1, "unit": "mL"}}
          ]
        },
        {
          "id": "chemostat-gates",
          "name": "wait for start gates",
          "description": "Begin dilution only after configured OD and elapsed-time gates are satisfied.",
          "step_type": "manual_gate",
          "execution_mode": "background_control_loop",
          "order_index": 2,
          "gates": [
            {"gate_type": "parameter_threshold", "parameter": "optical_density", "comparator": "greater_than_or_equal", "threshold": {"value": 0, "unit": "OD600"}},
            {"gate_type": "time_elapsed", "parameter": "elapsed_time", "comparator": "greater_than_or_equal", "threshold": {"value": 0, "unit": "hr"}}
          ],
          "action_ids": ["action-read-od"]
        },
        {
          "id": "chemostat-dilution",
          "name": "schedule bolus dilution",
          "description": "Approximate continuous perfusion with repeated small media boluses.",
          "step_type": "chemostat_dilution",
          "execution_mode": "background_control_loop",
          "order_index": 3,
          "fixed_parameters": [
            {"parameter": "bolus_volume", "value": {"value": 0.5, "unit": "mL"}},
            {"parameter": "flow_rate", "value": {"value": 0.75, "unit": "mL/s"}}
          ],
          "objectives": [
            {"objective_type": "keep_volume_constant", "parameter": "culture_volume", "target": {"value": 30, "unit": "mL"}}
          ],
          "action_ids": ["action-run-pump-forward"]
        }
      ],
      "documentation_ids": ["doc-chemostat"]
    },
    {
      "id": "turbidostat-standard",
      "name": "Turbidostat",
      "description": "Maintain cultures inside an OD band by calculating dilution volume when OD exceeds the upper threshold.",
      "protocol_type": "turbidostat",
      "version": "demo-2026.07",
      "algorithm_id": "alg-turbidostat-threshold-dilution",
      "required_device_types": ["smart_sleeve", "pump_rack"],
      "required_component_types": ["vial", "od_sensor", "temperature_sensor", "stirbar", "pump_influx", "pump_efflux"],
      "required_materials": [
        {"material_id": "mat-lb", "material_type": "growth_medium", "role": "media_input", "placeholder_allowed": false, "user_fill_required": false, "run_blocking_if_unresolved": false},
        {"material_id": "mat-ecoli", "material_type": "organism", "role": "inoculum", "placeholder_allowed": false, "user_fill_required": false, "run_blocking_if_unresolved": false},
        {"material_id": "mat-waste-output", "material_type": "waste", "role": "waste_output", "placeholder_allowed": false, "user_fill_required": false, "run_blocking_if_unresolved": false}
      ],
      "initial_conditions": [
        {"parameter": "temperature", "value": {"value": 30, "unit": "degree_C"}},
        {"parameter": "stir_rate", "value": {"value": 8, "unit": "setting"}},
        {"parameter": "culture_volume", "value": {"value": 25, "unit": "mL"}},
        {"parameter": "od_lower_threshold", "value": {"value": 0.5, "unit": "OD600"}},
        {"parameter": "od_upper_threshold", "value": {"value": 1.0, "unit": "OD600"}}
      ],
      "steps": [
        {
          "id": "turbidostat-load",
          "name": "load turbidostat lines",
          "description": "Connect sterile media and waste paths for each active vial.",
          "step_type": "setup_connections",
          "execution_mode": "manual",
          "order_index": 1,
          "material_inputs": [
            {"input_type": "initial_fill", "controlled_by_evolver": false, "material_id": "mat-lb", "amount": {"value": 25, "unit": "mL"}},
            {"input_type": "sample_spike", "controlled_by_evolver": false, "material_id": "mat-ecoli", "amount": {"value": 1, "unit": "mL"}}
          ]
        },
        {
          "id": "turbidostat-monitor",
          "name": "monitor OD band",
          "description": "Continuously monitor OD and calculate dilution when OD exceeds the upper threshold.",
          "step_type": "maintain_od",
          "execution_mode": "background_control_loop",
          "order_index": 2,
          "objectives": [
            {"objective_type": "maintain_parameter", "parameter": "optical_density", "lower_bound": {"value": 0.5, "unit": "OD600"}, "upper_bound": {"value": 1.0, "unit": "OD600"}}
          ],
          "action_ids": ["action-read-od", "action-read-temperature"]
        },
        {
          "id": "turbidostat-dilution",
          "name": "execute paired dilution",
          "description": "Run influx and efflux together, then overrun efflux to keep volume constant.",
          "step_type": "turbidostat_dilution",
          "execution_mode": "automatic",
          "order_index": 3,
          "fixed_parameters": [
            {"parameter": "flow_rate", "value": {"value": 0.75, "unit": "mL/s"}},
            {"parameter": "pump_duration", "value": {"value": 20, "unit": "s"}}
          ],
          "objectives": [
            {"objective_type": "perform_dilution", "parameter": "optical_density"},
            {"objective_type": "keep_volume_constant", "parameter": "culture_volume", "target": {"value": 25, "unit": "mL"}}
          ],
          "action_ids": ["action-run-pump-forward"]
        }
      ],
      "documentation_ids": ["doc-turbidostat"]
    }
  ],
  "experiments": [
