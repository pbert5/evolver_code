  "algorithms": [
    {
      "id": "alg-growth-curve-monitor",
      "name": "Growth curve monitor",
      "description": "Records optical density and temperature without feedback dilution.",
      "algorithm_type": "growth_curve",
      "input_parameters": ["optical_density", "temperature", "stir_rate"],
      "output_actions": ["action-read-od", "action-read-temperature"],
      "equations": [
        {"name": "no_feedback", "expression": "observe(optical_density, temperature)", "description": "Growth curve runs monitor sensors without pump feedback.", "variables": ["optical_density", "temperature"]}
      ],
      "documentation_ids": ["doc-growth-curve"]
    },
    {
      "id": "alg-chemostat-bolus-scheduler",
      "name": "Chemostat bolus scheduler",
      "description": "Approximates a dilution-rate control loop with repeated small pump boluses.",
      "algorithm_type": "chemostat",
      "input_parameters": ["optical_density", "elapsed_time", "flow_rate", "culture_volume", "dilution_rate", "bolus_volume"],
      "output_actions": ["action-run-pump-forward"],
      "equations": [
        {"name": "growth_rate_from_doubling_time", "expression": "ln(2) / doubling_time_hr", "variables": ["doubling_time_hr"]},
        {"name": "pump_period_seconds", "expression": "bolus_volume_mL / (dilution_rate_per_hr * culture_volume_mL) * 3600", "variables": ["bolus_volume_mL", "dilution_rate_per_hr", "culture_volume_mL"]}
      ],
      "documentation_ids": ["doc-chemostat"]
    },
    {
      "id": "alg-turbidostat-threshold-dilution",
      "name": "Turbidostat threshold dilution",
      "description": "Calculates dilution duration from OD thresholds, vessel volume, and pump flow rate.",
      "algorithm_type": "turbidostat",
      "input_parameters": ["optical_density", "od_lower_threshold", "od_upper_threshold", "flow_rate", "culture_volume"],
      "output_actions": ["action-run-pump-forward"],
      "equations": [
        {"name": "dilution_time_seconds", "expression": "-ln(lower_threshold / average_od) * culture_volume_mL / flow_rate_mL_per_s", "variables": ["lower_threshold", "average_od", "culture_volume_mL", "flow_rate_mL_per_s"]},
        {"name": "doubling_time_hours", "expression": "ln(2) / growth_rate_per_hr", "variables": ["growth_rate_per_hr"]}
      ],
      "documentation_ids": ["doc-turbidostat"]
    }
  ],
